NODE_ENV=development
PORT=3010

# PostgreSQL (docker compose — host port 5433)
DATABASE_URL=postgresql://wallet:wallet@127.0.0.1:5433/wallet_api?schema=public

# Redis — local / docker compose (host port 6380)
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_KEY_PREFIX=wallet-api:
# Managed Redis (Upstash, Render, etc.) — when set, overrides HOST/PORT
# REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379
# REDIS_PASSWORD=   # only if not embedded in REDIS_URL

# JWT (HS256) — change before deploy
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Flutterwave — real API via common/services-external/flutterwave
# Local mock: FLUTTERWAVE_MOCK=true (webhook verif-hash = mock-webhook-secret)
# Live: FLUTTERWAVE_MOCK=false + keys below
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
FLUTTERWAVE_REDIRECT_URL=http://localhost:3010/funding/callback
FLUTTERWAVE_MOCK=true

# Swagger: enabled when NODE_ENV !== production, or set true in prod
# SWAGGER_ENABLED=true
