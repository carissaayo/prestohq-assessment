NODE_ENV=development
PORT=3010

# PostgreSQL (docker compose — host port 5433 to avoid clashing with other local DBs)
DATABASE_URL=postgresql://wallet:wallet@127.0.0.1:5433/wallet_api?schema=public

# Redis (docker compose — host port 6380)
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
# REDIS_URL=redis://127.0.0.1:6380
REDIS_KEY_PREFIX=wallet-api:

# JWT (HS256) — change before deploy
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Flutterwave (Task 3+) — leave empty / set FLUTTERWAVE_MOCK=true for local mock
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
FLUTTERWAVE_REDIRECT_URL=http://localhost:3010/funding/callback
FLUTTERWAVE_MOCK=true

# Swagger: enabled when NODE_ENV !== production, or set true in prod
# SWAGGER_ENABLED=true
